{
  "manifest_version": 3,
  "name": "My Bubble",
  "version": "1.0",
  "description": "Filter negative news and protect your mental wellbeing.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs"
  ],
"host_permissions": [
  "<all_urls>",
  "https://api-inference.huggingface.co/*"
],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "My Bubble"
  }
}